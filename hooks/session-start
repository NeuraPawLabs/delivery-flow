#!/usr/bin/env bash
# SessionStart hook for delivery-flow plugin

set -euo pipefail
shopt -s extglob

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

read_bootstrap_contract() {
    local file_path="$1"
    local content

    content="$(<"$file_path")"
    content="${content//$'\r'/}"
    content="${content##+([[:space:]])}"
    content="${content%%+([[:space:]])}"

    printf '%s' "$content"
}

BOOTSTRAP_CONTENT="$(read_bootstrap_contract "${PLUGIN_ROOT}/skills/using-delivery-flow/bootstrap-contract.md")"
BOOTSTRAP="<EXTREMELY_IMPORTANT>\n${BOOTSTRAP_CONTENT}\n</EXTREMELY_IMPORTANT>"

escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

BOOTSTRAP="$(escape_for_json "$BOOTSTRAP")"

if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
    printf '{\n  "additional_context": "%s"\n}\n' "$BOOTSTRAP"
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ] && [ -z "${COPILOT_CLI:-}" ]; then
    printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$BOOTSTRAP"
else
    printf '{\n  "additionalContext": "%s"\n}\n' "$BOOTSTRAP"
fi

exit 0
